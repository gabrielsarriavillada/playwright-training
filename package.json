{
  "name": "playwright_learning",
  "version": "1.0.0",
  "description": "Playwright training project demonstrating Page Object Model (POM), test structure evolution, and scalable automation practices.",
  "author": "Gabriel Sarria Villada",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:jsonplaceholder-api": "playwright test --project=jsonplaceholder-api",
    "test:debug": "playwright test --debug",
    "test:qa-playground-chromium": "playwright test --project=qa-playground-chromium",
    "test:qa-playground-firefox": "playwright test --project=qa-playground-firefox",
    "test:qa-playground-webkit": "playwright test --project=qa-playground-webkit",
    "test:smoke": "playwright test --grep @smoke",
    "test:report": "playwright show-report",
    "install:browsers": "playwright install --with-deps",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.2",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.0"
  }
}
